{
  "connection": {
    "url": "ws://localhost:8080",
    "txRate": 10,
    "wdTimeout": 100
  },
  "inputs": [
    {
      "name": "uiWatchdog_Inputs",
      "type": "BYTE"
    },
    {
      "name": "xStart",
      "type": "BIT"
    },
    {
      "name": "xModeAuto",
      "type": "BIT"
    },
    {
      "name": "rSpeedSetpoint",
      "type": "REAL"
    },
    {
      "name": "iTargetPosition",
      "type": "INT"
    },
    {
      "name": "uiCycleCount",
      "type": "UINT"
    },
    {
      "name": "diEncoderRaw",
      "type": "DINT"
    },
    {
      "name": "byStatusBits",
      "type": "BYTE"
    },
    {
      "name": "sProductName",
      "type": "STRING",
      "length": 20
    }
  ],
  "outputs": [
    {
      "name": "uiWatchdog_Outputs",
      "type": "BYTE"
    },
    {
      "name": "xLightWarning",
      "type": "BIT"
    },
    {
      "name": "xMotorRunning",
      "type": "BIT"
    },
    {
      "name": "rActualSpeed",
      "type": "REAL"
    },
    {
      "name": "iActualPosition",
      "type": "INT"
    },
    {
      "name": "uiErrorID",
      "type": "UINT"
    },
    {
      "name": "diEncoderFeedback",
      "type": "DINT"
    },
    {
      "name": "byErrorCode",
      "type": "BYTE"
    },
    {
      "name": "sLogMessage",
      "type": "STRING",
      "length": 40
    }
  ]
}